cat > ~/.config/fcitx5/profile <<'EOF'
[Groups/0]
# Name=Default
# DefaultLayout=us
# DefaultIM=fcitx-keyboard-us

[Groups/0/DefaultIM]
# Name=fcitx-keyboard-us
# LangCode=en

[Groups/1]
# Name=Chinese
# DefaultLayout=us
# DefaultIM=pinyin

[Groups/1/DefaultIM]
# Name=pinyin
# LangCode=zh_CN

[Output/0]
# DefaultOutputLayout=us

[Hotkey]
# 【核心设置】中英文切换键 (仅使用 Ctrl+Space)
TriggerKey=CTRL_SPACE
IMSwitchKey=CTRL_SPACE
EOF

# 2. 写入拼音核心配置 (修正 Shift 问题版)
cat > ~/.config/fcitx5/conf/pinyin.conf <<'EOF'
# Fcitx 5 Pinyin 配置文件 - 最终完美版

# 【方案修正】标准全拼
ShuangpinProfile=Default

# 【云拼音优化】
# 1. 关闭动画，追求零延迟
CloudPinyinAnimation=False
# 2. 增大索引，提升网络热词匹配精准度
CloudPinyinIndex=2
KeepCloudPinyinPlaceHolder=False

# 【性能优化】
# 减少预测数，提升响应速度
Prediction=True
PredictionSize=3

# 【交互优化】
# 开启小键盘选词
UseKeypadAsSelection=True

# 【显示优化】
# 5个候选词，配合竖排使用
PageSize=5
# 开启竖排
Vertical Candidate List=True

# 【输入习惯】
# 【关键修正】禁用 Shift 临时切换中英文，Shift 仅作为普通上档键使用
SwitchKey=None
PreeditCursorPositionAtBeginning=True
PreeditMode="Composing pinyin"
SwitchInputMethodBehavior="Commit current preedit"

# 【准确度优化】
# 开启原始输入上屏
CommitRawInput=True

# 【快捷键优化】
# 保留分号快速输入
QuickPhraseKey=semicolon
VAsQuickphrase=True

# 自定义 2/3 选词键
[SecondCandidate]
0=Control+comma
[ThirdCandidate]
0=Control+period

# 【逻辑修正】关闭“以形取音”滤镜
FilterByStroke=False

# 【其他保持】
LongWordLengthLimit=6
CloudPinyinEnabled=True
EOF

# 3. 写入外观配置 (保留思源黑体版)
cat > ~/.config/fcitx5/conf/classicui.conf <<'EOF'
# Fcitx 5 Classic UI 配置文件 - 最终完美版

# 【显示模式】竖排候选列表
Vertical Candidate List=True

# 【翻页】启用鼠标滚轮
WheelForPaging=True

# 【字体配置】清晰字体，字号 14
# 注意：如果系统未安装 Noto Sans CJK SC，可能会回退到默认字体
# Ubuntu/Debian 安装命令: sudo apt install fonts-noto-cjk
Font="Noto Sans CJK SC 14"
MenuFont="Noto Sans CJK SC Bold 14"
TrayFont="Noto Sans CJK SC Bold 14"

# 【主题】深色主题
Theme=default-dark
UseDarkTheme=True
UseAccentColor=True

# 【图标设置】
ShowLayoutNameInIcon=True
UseInputMethodLanguageToDisplayText=True
TrayOutlineColor=#000000
TrayTextColor=#ffffff

# 【其他优化】
EnableFractionalScale=True
PerScreenDPI=False
ForceWaylandDPI=0
EOF

# 4. 重启 Fcitx5
fcitx5 -r
